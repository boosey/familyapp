# Hoisted linker: a flat node_modules with no internal symlinks.
#
# History: originally required because the repo lived on Google Drive, whose filesystem
# can't do pnpm's default symlinked store layout. The repo is now on a local NTFS volume
# that DOES support symlinks, so that original reason no longer applies.
#
# We deliberately keep hoisted anyway. Switching to the default isolated/symlinked linker
# was tested (2026-07-16): install/typecheck/tests all pass, BUT the symlinked layout changes
# how PGlite resolves its wasm path and breaks the `next build` prerender. Since this file
# governs the Vercel PRODUCTION build, do NOT flip the linker without validating on a Vercel
# preview deploy first — it is not a local-only decision.
node-linker=hoisted
symlink=false
shamefully-hoist=true
