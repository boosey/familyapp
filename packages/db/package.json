{
  "name": "@chronicle/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema-public.ts",
    "./content": "./src/content.ts",
    "./kinship": "./src/kinship.ts",
    "./testing": "./src/testing.ts"
  },
  "scripts": {
