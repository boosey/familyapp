# =============================================================================
# Family Chronicle — apps/web environment
# =============================================================================
# Copy to `.env.local` for local dev (Next.js loads .env.local from apps/web),
# and set the same keys in your host's env (Vercel) for production. Never commit
# real secrets — this file documents NAMES and shapes only.
#
# Runtime-switch philosophy: most integrations activate ONLY when their keys are
# present. With keys absent (local dev / CI) the app falls back to deterministic
# in-process mocks so `pnpm dev` runs end-to-end with no external accounts. So a
# minimal local .env.local can be nearly empty; production needs the full set.
# =============================================================================


# --- Database (Neon / managed Postgres) -------------------------------------
# Pooled connection string. PRESENT → the app uses managed Postgres; ABSENT →
# local PGlite (dev/CI). Required in production. Use the Neon PRODUCTION branch
# pooled host (…-pooler…) in prod, the dev branch locally.
DATABASE_URL=

# Direct (unpooled) connection string — used by schema/migration tooling
# (drizzle-kit) and anything that needs a non-pooled session. Same branch as
# DATABASE_URL, without the "-pooler" host segment. (Primarily read from the
# monorepo-root .env by tooling; included here for completeness.)
DATABASE_URL_UNPOOLED=

# First-boot schema bootstrap. Set to "1" ONCE to create the schema on a fresh
# managed-Postgres branch (create-if-absent, never drops). Leave unset normally
# so every cold start / HMR cycle doesn't re-run it.
CHRONICLE_RUN_MIGRATIONS=

# Informational: which Neon branch DATABASE_URL points at (dev | production).
# Not read by the app; a label to prevent dev/prod mix-ups.
NEON_BRANCH=


# --- Media storage (Cloudflare R2, S3-compatible) ---------------------------
# ALL FOUR or NONE. All four present → media persists to R2 (required in prod;
# the serverless filesystem is ephemeral and would lose uploads). None present →
# local filesystem store (dev). A PARTIAL set (1–3 of 4) FAILS LOUD at boot by
# design, so a half-configured prod deploy can't silently drop recordings.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=


# --- Durable job queue (Inngest) --------------------------------------------
# INNGEST_EVENT_KEY present → the transcribe→render pipeline runs out-of-band on
# Inngest (required in prod; multi-minute jobs would otherwise risk serverless
# timeouts). Absent → the pipeline runs synchronously in-process (dev/CI).
INNGEST_EVENT_KEY=
# REQUIRED whenever INNGEST_EVENT_KEY is set: the serve route (/api/inngest) uses
# it to verify Inngest's inbound execution calls. Event key WITHOUT signing key
# FAILS LOUD at boot — otherwise jobs would never run and stories would sit in
# "draft" forever, silently.
INNGEST_SIGNING_KEY=


# --- AI vendors -------------------------------------------------------------
# Groq drives BOTH transcription (Whisper) and story rendering (LLM). Present →
# real AI; absent → deterministic scripted mocks (dev/CI).
GROQ_API_KEY=
# Optional: override the Groq LLM model (default: llama-3.3-70b-versatile).
GROQ_LLM_MODEL=
# Optional LLM fallback, used ONLY when GROQ_API_KEY is absent. Dormant if Groq
# is configured.
ANTHROPIC_API_KEY=


# --- Auth (Clerk) -----------------------------------------------------------
# BOTH present (with valid pk_/sk_ prefixes) → real Clerk auth. Absent → the
# mock email+password provider (dev/CI). Use pk_test_/sk_test_ in dev, and
# pk_live_/sk_live_ in production.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=


# --- Google Photos Picker (optional) ----------------------------------------
# ALL THREE or NONE. All three present → Connect / Import / Disconnect chrome
# on the album. Absent → file upload only. Encryption key must be 32 raw bytes,
# base64-encoded (e.g. `openssl rand -base64 32`).
GOOGLE_PHOTOS_CLIENT_ID=
GOOGLE_PHOTOS_CLIENT_SECRET=
GOOGLE_PHOTOS_TOKEN_ENCRYPTION_KEY=


# --- App ---------------------------------------------------------------------
# Canonical public origin for building absolute, shareable links (invite links,
# etc.), e.g. https://app.example.com — MUST include the scheme. Preferred over
# the request Host header so links are stable. In PRODUCTION, if this is unset
# AND the Host header is somehow absent, link generation FAILS LOUD rather than
# emitting a dead http://localhost link.
APP_BASE_URL=


# --- Error monitoring (Sentry) ----------------------------------------------
# DSN present → the app reports errors to Sentry (client + server + edge). Absent
# → the SDK is injected by the build but stays inert at runtime (no phone-home).
# The DSN is public-by-design (safe to expose to the browser); the AUTH_TOKEN is
# the secret and belongs only in the build/CI env (Vercel), never in the client.
NEXT_PUBLIC_SENTRY_DSN=
# Server-side DSN. Usually the same value as NEXT_PUBLIC_SENTRY_DSN; kept separate
# so the server can report even if the public var is scoped away.
SENTRY_DSN=
# Optional: trace sample rate (0..1). Default 0 (errors only, no perf traces).
SENTRY_TRACES_SAMPLE_RATE=
# --- Build-time only (source-map upload; set in Vercel/CI, NOT in .env.local) --
# ALL THREE or NONE. All three present at BUILD time → source maps upload so
# stack traces de-minify. AUTH_TOKEN is a secret (Vercel env only). Absent → the
# build still succeeds and simply skips upload.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=


# --- Operational (usually set by the platform/tooling; rarely set by hand) ----
# NODE_ENV       — "production" in prod; set by the framework/host.
# PORT           — dev server port (default 3000).
# CI             — set by CI; tweaks Playwright behavior.
# PW_REUSE_SERVER — local Playwright: reuse an already-running dev server.
