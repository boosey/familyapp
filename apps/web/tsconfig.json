{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "preserve",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "node",
      "react",
      "react-dom"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "verbatimModuleSyntax": false,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@chronicle/db": [
        "../../packages/db/src/index.ts"
      ],
      "@chronicle/db/schema": [
        "../../packages/db/src/schema-public.ts"
      ],
      "@chronicle/db/content": [
        "../../packages/db/src/content.ts"
      ],
      "@chronicle/core": [
        "../../packages/core/src/index.ts"
      ],
      "@chronicle/capture": [
        "../../packages/capture/src/index.ts"
      ],
      "@chronicle/storage": [
        "../../packages/storage/src/index.ts"
      ],
      "@chronicle/core/pipeline": [
        "../../packages/core/src/pipeline.ts"
      ],
      "@chronicle/pipeline": [
        "../../packages/pipeline/src/index.ts"
      ],
      "@chronicle/interviewer": [
        "../../packages/interviewer/src/index.ts"
      ],
      "@chronicle/queue-inngest": [
        "../../packages/queue-inngest/src/index.ts"
      ],
      "@chronicle/transcribe-groq": [
        "../../packages/transcribe-groq/src/index.ts"
      ],
      "@chronicle/llm-anthropic": [
        "../../packages/llm-anthropic/src/index.ts"
      ],
      "@chronicle/llm-groq": [
        "../../packages/llm-groq/src/index.ts"
      ],
      "@chronicle/photos-google": [
        "../../packages/photos-google/src/index.ts"
      ],
      "@chronicle/photos-google/picker": [
        "../../packages/photos-google/src/picker.ts"
      ],
      "@/*": [
        "./*"
      ]
    },
    "incremental": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    ".next-tmp/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
