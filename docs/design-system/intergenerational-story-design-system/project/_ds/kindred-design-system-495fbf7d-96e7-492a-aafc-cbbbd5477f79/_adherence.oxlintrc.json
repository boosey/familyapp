{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "ui_kits/kindred-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Newsreader|Public Sans|DM Mono))/i]",
        "message": "Font not provided by the design system. Available: Newsreader, Public Sans, DM Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='KindredButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|fullWidth|disabled|leadingIcon|key|ref|className|style|children)$/]",
        "message": "<KindredButton> doesn't accept that prop. Declared props: children, variant, size, fullWidth, disabled, leadingIcon."
      },
      {
        "selector": "JSXOpeningElement[name.name='KindredButton'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<KindredButton> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KindredButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:small|default|large)$/]",
        "message": "<KindredButton> size must be one of 'small' | 'default' | 'large'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KindredChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|selected|leadingIcon|onClick|style|key|ref|className|style|children)$/]",
        "message": "<KindredChip> doesn't accept that prop. Declared props: children, selected, leadingIcon, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='KindredListenBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:playing|duration|title|onToggle|style|key|ref|className|style|children)$/]",
        "message": "<KindredListenBar> doesn't accept that prop. Declared props: playing, duration, title, onToggle, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='KindredPromptCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:prompt|eyebrow|forName|onAnswer|style|key|ref|className|style|children)$/]",
        "message": "<KindredPromptCard> doesn't accept that prop. Declared props: prompt, eyebrow, forName, onAnswer, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='KindredStoryCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|year|place|excerpt|imageSrc|duration|pinned|onClick|style|key|ref|className|style|children)$/]",
        "message": "<KindredStoryCard> doesn't accept that prop. Declared props: title, year, place, excerpt, imageSrc, duration, pinned, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='KindredVoiceButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:listening|label|onClick|size|style|key|ref|className|style|children)$/]",
        "message": "<KindredVoiceButton> doesn't accept that prop. Declared props: listening, label, onClick, size, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {
      "KindredButton": {
        "replaces": []
      },
      "KindredChip": {
        "replaces": []
      },
      "KindredListenBar": {
